# Database URL - Use Vercel Postgres connection string in production
DATABASE_URL="postgresql://user:password@localhost:5432/fitness"

# Prisma Data Proxy (optional, recommended for serverless hosts)
# If you enable Prisma Data Proxy, set this to your Data Proxy URL and
# PRISMA will route database requests through the proxy instead of
# requiring a native query engine in serverless functions.
PRISMA_DATA_PROXY_URL=""

# JWT secret key for authentication - Use a strong random string in production
JWT_SECRET="your-secret-key-32-characters-or-more-long"

